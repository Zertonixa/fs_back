# ================================
# Core / App
# ================================
APP__HOST=0.0.0.0
APP__PORT=8000
APP__WORKERS=1
APP__RELOAD=false
APP__DEBUG=false
APP__TZ_OFFSET_HOURS=3
APP__PROXY_HEADERS=false
# JSON array (pydantic парсит из строки)
APP__FORWARDED_ALLOW_IPS=["*"]

# ================================
# Logging
# ================================
LOGGING__LEVEL=INFO

# ================================
# Database (PostgreSQL)
# ================================
DATABASE__POSTGRES_USERNAME=postgres
DATABASE__POSTGRES_PASSWORD=postgres
DATABASE__POSTGRES_HOST=localhost
DATABASE__POSTGRES_PORT=5432
DATABASE__POSTGRES_DB=postgres

DATABASE__ECHO=false
DATABASE__POOL_PRE_PING=true
DATABASE__POOL_RECYCLE=1800
DATABASE__POOL_USE_LIFO=false
DATABASE__POOL_TIMEOUT=30
DATABASE__POOL_SIZE=5
DATABASE__MAX_OVERFLOW=10

# ================================
# S3 / MinIO
# ================================
S3__ENDPOINT=http://localhost:9000
S3__ACCESS_KEY=minioadmin
S3__SECRET_KEY=minioadmin
S3__BUCKET=bucket
S3__REGION=us-east-1
S3__USE_SSL=false
# path | virtual
S3__ADDRESSING_STYLE=path

# ================================
# Redis (Pub/Sub broker)
# - switch to rediss for TLS
# - SSL policy: none | required
# ================================
REDIS_PUBSUB__SCHEME=redis
REDIS_PUBSUB__HOST=redis
REDIS_PUBSUB__PORT=6379
REDIS_PUBSUB__DB=0
# optional auth (оставь пустым если не нужно)
REDIS_PUBSUB__USERNAME=
REDIS_PUBSUB__PASSWORD=
REDIS_PUBSUB__DECODE_RESPONSES=true
REDIS_PUBSUB__SSL_CERT_REQS=none

# pool/timeouts
REDIS_PUBSUB__MAX_CONNECTIONS=50
REDIS_PUBSUB__HEALTH_CHECK_INTERVAL=30
REDIS_PUBSUB__SOCKET_TIMEOUT=5.0
REDIS_PUBSUB__SOCKET_CONNECT_TIMEOUT=5.0
REDIS_PUBSUB__SOCKET_KEEPALIVE=true

# ================================
# Redis (Cache)
# ================================
REDIS_CACHE__SCHEME=redis
REDIS_CACHE__HOST=redis
REDIS_CACHE__PORT=6379
REDIS_CACHE__DB=1
# optional auth
REDIS_CACHE__USERNAME=
REDIS_CACHE__PASSWORD=
REDIS_CACHE__DECODE_RESPONSES=true
REDIS_CACHE__SSL_CERT_REQS=none

# pool/timeouts
REDIS_CACHE__MAX_CONNECTIONS=50
REDIS_CACHE__HEALTH_CHECK_INTERVAL=30
REDIS_CACHE__SOCKET_TIMEOUT=5.0
REDIS_CACHE__SOCKET_CONNECT_TIMEOUT=5.0
REDIS_CACHE__SOCKET_KEEPALIVE=true

# cache-specific
REDIS_CACHE__KEY_PREFIX=app:cache:
REDIS_CACHE__DEFAULT_TTL_SECONDS=3600
REDIS_CACHE__NEGATIVE_TTL_SECONDS=60

# ================================
# Docs
# JSON array of IPs (строкой)
# ================================
DOCS__ALLOWED_IPS=["123.123.123.123","124.124.124.124","125.125.125.125"]
